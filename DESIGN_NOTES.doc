  h1 { color: #381FF0; border-bottom: 2px solid #381FF0; padding-bottom: 10px; }
  h2 { color: #FF6B4A; margin-top: 30px; }
  h3 { color: #444; }
  ul { margin-bottom: 20px; }
  li { margin-bottom: 8px; }
  hr { border: 0; border-top: 1px solid #eee; margin: 40px 0; }
  .status { background: #f0f4ff; padding: 15px; border-radius: 8px; border-left: 4px solid #381FF0; }
</style>

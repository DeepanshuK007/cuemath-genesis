# Google OAuth (get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
REDIRECT_URI=http://localhost:5173

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-api-key-here

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key

# Stripe API Key (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here

# JWT Secret for session tokens (generate a random string)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-key

# Server & Environment
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database Configuration
# Default: Local SQLite (database.sqlite in project root)
# NOTE: Render's filesystem is ephemeral. To persist data, you MUST:
# 1. Create a "Disk" in Render (e.g., at /var/data)
# 2. Set DATABASE_PATH=/var/data/database.sqlite
DATABASE_PATH=database.sqlite

# If you prefer a managed database (PostgreSQL/MySQL), set this (requires code changes):
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Stripe Webhook Secret (Required for production payment sync)
# Get from https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
